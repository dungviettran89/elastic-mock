{
  "name": "elastic-mock",
  "version": "0.1.0",
  "description": "A lightweight, high-performance, in-memory Elasticsearch mock server backed by FlexSearch.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts serve --port 19200",
    "build": "tsc",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run test/integration",
    "test:external": "./scripts/run-external-tests.sh",
    "service:start": "npm run build && pm2 delete elastic-mock || true && pm2 start dist/index.js --name elastic-mock -- serve --port 19200",
    "service:stop": "pm2 stop elastic-mock || true",
    "service:log": "timeout 2s pm2 logs --lines 100 --no-daemon",
    "service:status": "pm2 status"
  },
  "keywords": [
    "elasticsearch",
    "mock",
    "flexsearch",
    "testing",
    "in-memory",
    "node"
  ],
  "author": "Dung Viet Tran",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dungviettran89/elastic-mock.git"
  },
  "bugs": {
    "url": "https://github.com/dungviettran89/elastic-mock/issues"
  },
  "homepage": "https://github.com/dungviettran89/elastic-mock#readme",
  "dependencies": {
    "commander": "^12.0.0",
    "express": "^4.19.2",
    "flexsearch": "^0.8.212",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@elastic/elasticsearch": "^8.13.1",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.7",
    "@types/supertest": "^7.2.0",
    "@types/winston": "^2.4.4",
    "glob": "^13.0.6",
    "js-yaml": "^4.1.1",
    "pm2": "^6.0.14",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  },
  "files": [
    "dist",
    "docs/README.md"
  ],
  "bin": {
    "elastic-mock": "./dist/index.js"
  }
}
